# Chain configuration
CHAIN_ID=11142220
RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Contract addresses (deploy first, then fill in)
FACTORY_ADDRESS=0x...
REGISTRY_ADDRESS=0x...
AGENT_REGISTRY_ADDRESS=0x...
PAYMENT_TOKEN_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a

# Mock randomness contract (testnet only)
MOCK_RANDOMNESS_ADDRESS=0x...

# House agent wallet (must be funded with stablecoin for deposits + CELO for gas)
PRIVATE_KEY=0x...

# Agent identity
AGENT_URI=https://raffletime.io/.well-known/house-agent.json

# Admission bond amount (default $1)
BOND_AMOUNT=1000000000000000000

# Beneficiary addresses (comma-separated)
BENEFICIARIES=0x...,0x...

# Raffle parameters
TICKET_PRICE=100000000000000000
RAFFLE_DURATION=3600
TARGET_POOL_SIZE=100000000000000000000

# Scheduler
RAFFLE_CYCLE_MS=3600000
POLL_INTERVAL_MS=15000

# Server
PORT=3000

# x402 payments (optional — leave unset to disable paywall in dev)
# X402_ENABLED=true
