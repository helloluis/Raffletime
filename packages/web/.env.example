# Chain: "sepolia", "alfajores", or "mainnet"
VITE_CHAIN=sepolia

# Contract addresses (deploy first, then fill in)
VITE_FACTORY_ADDRESS=0x...
VITE_REGISTRY_ADDRESS=0x...
VITE_AGENT_REGISTRY_ADDRESS=0x...
VITE_PAYMENT_TOKEN_ADDRESS=0x...

# House agent API URL
VITE_AGENT_API_URL=http://localhost:3000

# WalletConnect project ID (optional, for wallet connections)
# VITE_WALLETCONNECT_PROJECT_ID=your-project-id
